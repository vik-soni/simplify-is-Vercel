# Public URL for the deployed showcase site
NEXT_PUBLIC_APP_URL=https://simplify.is

# Waitlist emails via Resend (same keys as vik.so / main Simplify IS app)
# Get keys: https://resend.com/api-keys
# Verify sending domain, then use an address on that domain for FROM.
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=noreply@vik.so
VIK_ALERT_EMAIL=vik@simplify.is
